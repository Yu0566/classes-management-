{
  "name": "class-management",
  "version": "3.4.7",
  "description": "课堂管理系统 - 桌面端班级管理应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && tsc -p server/tsconfig.json && vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.node.json --watch\" \"wait-on file:.vite-tmp/port && electron .\"",
    "electron:build": "tsc -p tsconfig.node.json && tsc -p server/tsconfig.json && vite build && electron-builder",
    "electron:publish": "tsc -p tsconfig.node.json && tsc -p server/tsconfig.json && vite build && electron-builder --publish always",
    "publish:gitee": "npm run electron:build && node scripts/publish-gitee.js",
    "publish:gitee:only": "node scripts/publish-gitee.js",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "node dist-server/server/index.js",
    "server:dev": "tsc -p server/tsconfig.json && node dist-server/server/index.js --dev",
    "android:sync": "vite build && npx cap sync android",
    "android:build": "vite build && npx cap sync android && cd android && gradlew assembleDebug",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.3",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@electron/rebuild": "^4.0.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "docx": "^9.7.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "recharts": "^2.12.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.classmanagement.app",
    "productName": "课堂管理系统",
    "compression": "maximum",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/node_modules/better-sqlite3/deps/**",
      "!**/node_modules/better-sqlite3/src/**",
      "!**/node_modules/sql.js/dist/sql-asm*",
      "!**/node_modules/sql.js/dist/worker.sql-asm*",
      "!**/node_modules/sql.js/dist/*debug*",
      "!**/node_modules/sql.js/dist/*browser*"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/*.node"
    ],
    "publish": {
      "provider": "github",
      "owner": "Yu0566",
      "repo": "classes-management-"
    },
    "extraResources": [
      {
        "from": "seed.json",
        "to": "seed.json"
      },
      {
        "from": "tunnel/cert.pem",
        "to": "tunnel/cert.pem"
      },
      {
        "from": "tunnel/credentials.json",
        "to": "tunnel/credentials.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "include": "build/installer.nsh",
      "installerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
